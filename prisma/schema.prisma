generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  lineUserId   String   @unique
  displayName  String
  totalPoints  Int      @default(0)
  totalCo2Saved Float   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  trips        Trip[]
  session      UserSession?
}

model Trip {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  originLat   Float
  originLng   Float
  destLat     Float
  destLng     Float
  destLabel   String?
  mode        String   // BTS, MRT, BUS, ESCOOTER, BICYCLE, WALK
  distanceKm  Float
  co2Saved    Float
  points      Int
  createdAt   DateTime @default(now())
}

model UserSession {
  id          String   @id @default(cuid())
  lineUserId  String   @unique
  user        User     @relation(fields: [lineUserId], references: [lineUserId])
  step        String   // IDLE, WAITING_DESTINATION
  originLat   Float?
  originLng   Float?
  updatedAt   DateTime @updatedAt
}