datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

model User {
  id            String   @id @default(cuid())
  lineUserId    String   @unique
  displayName   String
  totalPoints   Int      @default(0)
  totalCo2Saved Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  trips         Trip[]
}

model Trip {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originLat Float
  originLng Float
  destLat   Float
  destLng   Float
  destLabel String?
  mode      String
  distanceKm Float
  co2Saved  Float
  points    Int
  createdAt DateTime @default(now())
}

model UserSession {
  id            String   @id @default(cuid())
  lineUserId    String   @unique
  updatedAt     DateTime @updatedAt
  step          String   @default("IDLE")
  originLat     Float?
  originLng     Float?
  destLat       Float?
  destLng       Float?
  destLabel     String?
  pendingRoutes Json?
}