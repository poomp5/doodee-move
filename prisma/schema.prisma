datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

model User {
  id            String   @id @default(cuid())
  lineUserId    String   @unique
  displayName   String
  totalPoints   Int      @default(0)
  totalCo2Saved Float    @default(0)
  pdpaConsent   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  trips         Trip[]
}

model Trip {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originLat Float
  originLng Float
  destLat   Float
  destLng   Float
  destLabel String?
  mode      String
  distanceKm Float
  co2Saved  Float
  points    Int
  createdAt DateTime @default(now())
}

model UserSession {
  id            String   @id @default(cuid())
  lineUserId    String   @unique
  updatedAt     DateTime @updatedAt
  step          String   @default("IDLE")
  originLat     Float?
  originLng     Float?
  destLat       Float?
  destLng       Float?
  destLabel     String?
  pendingRoutes Json?
  transitImageUrl String?
  transitData     String?
}

model TransitSubmission {
  id          String   @id @default(cuid())
  lineUserId  String
  displayName String
  imageUrl    String
  latitude    Float
  longitude   Float
  description String
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  @@index([status, createdAt(sort: Desc)])
}

model UserRating {
  id          String   @id @default(cuid())
  lineUserId  String?  // Optional: can be anonymous
  displayName String?  // Optional: store user name if available
  rating      Int      // 1-5 stars
  category    String   @default("usability") // usability, feature, overall, etc.
  source      String   @default("web")
  feedbackText String?
  routeMode   String?
  destLabel   String?
  userAgent   String?  // Browser/device info
  createdAt   DateTime @default(now())
  
  @@index([category, rating])
  @@index([source, createdAt])
  @@index([createdAt])
}
